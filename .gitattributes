# Default: auto-detect and normalise to LF on commit
* text=auto eol=lf

# Force LF for shell/JS/MD/YAML/JSON/HTML/CSS
*.sh    text eol=lf
*.js    text eol=lf
*.cjs   text eol=lf
*.mjs   text eol=lf
*.ts    text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.json  text eol=lf
*.html  text eol=lf
*.css   text eol=lf

# Windows batch must keep CRLF
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# Binaries
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.svg   binary
*.ico   binary
*.pdf   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
*.eot   binary
*.zip   binary
*.gz    binary
