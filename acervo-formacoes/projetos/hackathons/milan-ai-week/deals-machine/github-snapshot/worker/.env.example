# Deals Machine Worker — environment template
# Copy to .env and fill in. On Vultr, the real file lives at /etc/deals-machine.env (chmod 600).

# --- Supabase (service-role key — server-side only, never exposed to browser) ---
SUPABASE_URL=https://mvvlqvakymkqruecrvmf.supabase.co
SUPABASE_SERVICE_KEY=

# --- LLMs ---
ANTHROPIC_API_KEY=
# OpenAI is for Whisper fallback when Speechmatics is unavailable
OPENAI_API_KEY=

# --- Granola auto-pickup (PRIMARY transcript ingestion path) ---
# Worker polls Granola every 5 minutes for new meeting transcripts,
# matches them to leads via Claude classifier, ingests into Brain.
GRANOLA_API_TOKEN=
# Polling interval in seconds (default 300 = 5 min). Set to 0 to disable.
GRANOLA_POLL_INTERVAL=300

# --- Fireflies auto-pickup (secondary path, optional) ---
FIREFLIES_API_TOKEN=

# --- Audio transcription (Speechmatics primary, Whisper fallback) ---
# Used for both Twilio click-to-call recordings AND the manual audio-upload path.
SPEECHMATICS_API_KEY=

# --- Twilio (PRIMARY audio path: click-to-call → carrier-level recording → Brain) ---
# Sign up at twilio.com → buy a number → API credentials from console.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Your purchased Twilio number, +E.164 format (e.g. +15551234567).
TWILIO_FROM_NUMBER=
# Public URL where Twilio webhooks land — must be https. On Vultr this is
# https://worker.kyletdow.com — locally with `ngrok http 3000` it's the ngrok URL.
TWILIO_WEBHOOK_BASE=https://worker.kyletdow.com

# --- Lead data ---
APOLLO_API_KEY=

# --- CRM ---
HUBSPOT_API_KEY=

# --- Signal sources ---
NEWSAPI_KEY=

# --- Security middleware (Veea Lobster Trap on the same Vultr host) ---
# Default points at the local container. Empty = regex-fallback path.
LOBSTER_TRAP_URL=http://127.0.0.1:8080/v1

# --- Shared secret between Vercel cockpit and Vultr worker ---
# Cockpit forwards every request with header `x-worker-secret: $WORKER_PROXY_SECRET`.
# Generate with: openssl rand -hex 32
WORKER_PROXY_SECRET=

# --- Runtime ---
PORT=3000
NODE_ENV=production
LOG_LEVEL=info
