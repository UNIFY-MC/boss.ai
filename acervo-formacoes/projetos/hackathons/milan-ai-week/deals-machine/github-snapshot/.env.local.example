# Deals Machine Cockpit — environment template (Vercel-hosted)
# Copy to .env.local for local dev. In Vercel, set the same values in the project's Env tab.

# --- Supabase (browser-safe anon key) ---
NEXT_PUBLIC_SUPABASE_URL=https://mvvlqvakymkqruecrvmf.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Server-only Supabase (service-role for /api routes that need privileged writes) ---
SUPABASE_SERVICE_KEY=

# --- Worker URL (Vultr-hosted agent service) ---
# Production: https://worker.kyletdow.com
# Local dev:  http://localhost:3000
WORKER_URL=https://worker.kyletdow.com

# --- Shared secret between cockpit and worker ---
# Must match WORKER_PROXY_SECRET in worker/.env.
# Generate with: openssl rand -hex 32
WORKER_PROXY_SECRET=

# --- Legacy keys (still used by some existing /api routes; deprecate once worker handles all external calls) ---
ANTHROPIC_API_KEY=
APOLLO_API_KEY=
RESEND_API_KEY=
